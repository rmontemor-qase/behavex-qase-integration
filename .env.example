# --------------------------------------------------------------------------
# Qase reporter credentials
#
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# Then load it into your shell before running the suite:
#     set -a && source .env && set +a
#
# `.env` is gitignored. NEVER commit real tokens.
# Environment variables take precedence over qase.config.json.
# --------------------------------------------------------------------------

# Reporting mode: "testops" (push to Qase) | "report" (local JSON only) | "off"
QASE_MODE=testops

# If pushing to Qase fails, fall back to writing a local JSON report
QASE_FALLBACK=report

# Your Qase project code (visible in the URL: app.qase.io/project/<CODE>)
QASE_TESTOPS_PROJECT=YOUR_PROJECT_CODE

# Personal API token — create one at https://app.qase.io/user/api/token
QASE_TESTOPS_API_TOKEN=YOUR_API_TOKEN

# Optional: customize the run that shows up in Qase
QASE_TESTOPS_RUN_TITLE="BehaveX + Qase demo run"
QASE_TESTOPS_RUN_COMPLETE=true
